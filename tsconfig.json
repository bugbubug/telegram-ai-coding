{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@core/*": ["./src/core/*"],
      "@services/*": ["./src/services/*"],
      "@bot/*": ["./src/bot/*"],
      "@plugins/*": ["./src/plugins/*"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "eslint.config.js"],
  "exclude": ["node_modules", "dist", "workspaces"]
}
